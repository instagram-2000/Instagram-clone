rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Keep this list in sync with VITE_SUPERADMIN_EMAILS — this is the real
    // enforcement point, the env var is UI-only.
    function isSuperAdminEmail() {
      return request.auth != null &&
        request.auth.token.email in [
          'vaibhavvakil1234@gmail.com'
          // add more superadmin emails here, one per line
        ];
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasUserDoc() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // Defense in depth: also honor a Firestore-recorded SUPERADMIN role, so
    // a superadmin added after go-live doesn't require a rules redeploy.
    function isSuperAdminDoc() {
      return hasUserDoc() && currentUserDoc().role == 'SUPERADMIN';
    }

    function isSuperAdmin() {
      return isSuperAdminEmail() || isSuperAdminDoc();
    }

    // A hospital admin managing their own hospital's doctors, receptionists,
    // patients and appointments — never someone else's hospital.
    function isHospitalAdminOf(hospitalId) {
      return hasUserDoc() &&
        currentUserDoc().role == 'HOSPITAL_ADMIN' &&
        currentUserDoc().hospitalId == hospitalId &&
        currentUserDoc().status == 'active';
    }

    // Any active staff member (of any role) of the given hospital — used
    // for patient/appointment access, and for cross-role visibility (e.g.
    // a receptionist listing doctors, a doctor's own dashboard).
    function isHospitalStaffOf(hospitalId) {
      return hasUserDoc() &&
        currentUserDoc().hospitalId == hospitalId &&
        currentUserDoc().status == 'active';
    }

    // A doctor may update their own record (schedule, specialization,
    // display name) but never their role, hospital, status or email —
    // those stay hospital-admin/superadmin-only.
    function isSelfDoctorScheduleUpdate(uid) {
      return request.auth != null && request.auth.uid == uid &&
        resource.data.role == 'DOCTOR' &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.hospitalId == resource.data.hospitalId &&
        request.resource.data.status == resource.data.status &&
        request.resource.data.email == resource.data.email;
    }

    // Doctor directory entries (name, specialization, schedule) are
    // intentionally public — patients need them to pick a doctor when
    // booking, without any login.
    function isActiveDoctorDoc() {
      return resource.data.role == 'DOCTOR' && resource.data.status == 'active';
    }

    match /hospitals/{slug} {
      allow read: if true; // public tenant landing pages read without auth
      allow create, update, delete: if isSuperAdmin();
    }

    match /users/{uid} {
      allow get: if isActiveDoctorDoc() ||
        (request.auth != null &&
          (request.auth.uid == uid || isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId)));
      allow list: if isActiveDoctorDoc() || isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);

      allow create: if isSuperAdmin() ||
        (isHospitalAdminOf(request.resource.data.hospitalId) &&
         request.resource.data.role in ['DOCTOR', 'RECEPTIONIST']);

      // A hospital admin may update their own doctors'/receptionists'
      // status and schedule, but never change their role or move them to
      // a different hospital (that would be a privilege-escalation path).
      // A doctor may separately update only their own record's schedule.
      allow update: if isSuperAdmin() ||
        (isHospitalAdminOf(resource.data.hospitalId) &&
         resource.data.role in ['DOCTOR', 'RECEPTIONIST'] &&
         request.resource.data.role == resource.data.role &&
         request.resource.data.hospitalId == resource.data.hospitalId) ||
        isSelfDoctorScheduleUpdate(uid);

      allow delete: if isSuperAdmin();
    }

    match /patients/{patientId} {
      allow read: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      // Public self-service booking creates its own patient record — no
      // login, so this can only be shape-checked, not identity-checked.
      allow create: if isHospitalStaffOf(request.resource.data.hospitalId) ||
        (request.resource.data.hospitalId is string &&
         request.resource.data.name is string &&
         request.resource.data.phone is string);
      allow update: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow delete: if isSuperAdmin();
    }

    match /appointments/{appointmentId} {
      // The doc ID doubles as an unguessable public lookup token (see
      // getAppointmentByToken) — anyone who has it can fetch that one
      // appointment, but never enumerate the collection (allow list stays
      // staff-only below).
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      // Staff book already-confirmed appointments; the public booking page
      // may only create ones that start 'pending' front-desk confirmation.
      allow create: if isHospitalStaffOf(request.resource.data.hospitalId) ||
        (request.resource.data.status == 'pending' && request.resource.data.bookedBy == 'patient');
      allow update: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow delete: if isSuperAdmin();
    }

    // Doc ID is `{hospitalId}::{digitsOnlyPhone}` — lets the public status
    // page resolve "my appointments" from a phone number alone via a
    // direct get-by-ID, the same unguessable-ID pattern as appointment
    // tokens, without ever exposing an open query across all patients.
    match /phoneLookup/{lookupId} {
      allow get: if true;
      allow list: if isSuperAdmin() || isHospitalStaffOf(resource.data.hospitalId);
      allow create, update: if request.resource.data.hospitalId is string && request.resource.data.tokens is list;
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
